---
import { ArrowUpRight } from 'lucide-astro';
---

<div class="newsletter-card">
  <h4 class="card-title">The Ledger</h4>
  <p class="card-description">
    Stop guessing. Start testing. The technical ecommerce newsletter for founders.
  </p>
  
  <form class="newsletter-form">
    <div class="input-group">
      <input type="email" placeholder="YOUR EMAIL" required />
    </div>
    <button type="submit" class="submit-btn">
      JOIN_LEDGER <ArrowUpRight size={18} />
    </button>
  </form>
  
  <div class="card-footer">
    <span class="status">LIVE FEED_ON</span>
  </div>
</div>

<style>
  .newsletter-card {
    background: var(--primary);
    padding: 2.5rem;
    border: 2px solid var(--black);
    border-radius: 0;
    position: sticky;
    top: 8rem;
    box-shadow: 12px 12px 0px var(--black);
    transition: var(--transition-smooth);
  }

  .newsletter-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 16px 16px 0px var(--black);
  }

  .card-title {
    font-size: 2.5rem;
    line-height: 0.9;
    margin-bottom: 1.5rem;
  }

  .card-description {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 2rem;
    color: rgba(0,0,0,0.8);
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .input-group input {
    width: 100%;
    padding: 1.25rem;
    background: var(--white);
    border: 2px solid var(--black);
    border-radius: 0;
    font-family: inherit;
    font-weight: 900;
    font-size: 0.75rem;
    text-transform: uppercase;
    outline: none;
  }

  .input-group input::placeholder {
    color: var(--zinc-400);
  }

  .submit-btn {
    width: 100%;
    padding: 1.25rem;
    background: var(--black);
    color: var(--white);
    border-radius: 0;
    font-weight: 900;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: var(--transition-fast);
  }

  .submit-btn:hover {
    background: var(--zinc-900);
    gap: 1rem;
  }

  .card-footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  .status {
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    opacity: 0.5;
  }

  @media (max-width: 1024px) {
    .newsletter-card {
      position: static;
      margin-top: 4rem;
    }
  }
</style>
