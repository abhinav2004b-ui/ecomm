---
import { FlaskConical, Twitter, Linkedin, Instagram } from 'lucide-astro';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-accent"></div>
  <div class="container footer-content">
    <div class="footer-top">
      <div class="footer-brand">
        <FlaskConical size={40} class="amber-fill" />
        <h2 class="footer-logo">EASY <span class="amber">ECOM</span></h2>
      </div>
      
      <div class="footer-socials">
        <a href="https://x.com/alex_easyecom" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="X"><Twitter size={24} /></a>
        <a href="https://www.linkedin.com/in/alex-e-ecom/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn"><Linkedin size={24} /></a>
        <a href="#" class="social-link" aria-label="Instagram"><Instagram size={24} /></a>
      </div>
    </div>

    <div class="footer-nav">
      <div class="nav-column">
        <h3 class="column-title">Intelligence</h3>
        <a href="/shopify">Shopify</a>
        <a href="/woocommerce">WooCommerce</a>
      </div>
      <div class="nav-column">
        <h3 class="column-title">Platform</h3>
        <a href="/about">About Alex</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">© {year} EASY ECOM // RESEARCH BY ALEX R.</p>
      <div class="status-indicator">
        <span class="dot"></span>
        SYSTEMS_OPERATIONAL
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--black);
    color: var(--white);
    padding: 6rem 0 3rem;
    position: relative;
  }

  .footer-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 8px;
    background: var(--primary);
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 5rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-logo {
    font-size: 2.5rem;
    line-height: 1;
  }

  .amber { color: var(--primary); }
  .amber-fill { color: var(--primary); fill: var(--primary); }

  .footer-socials {
    display: flex;
    gap: 2rem;
  }

  .social-link {
    color: var(--zinc-500);
    transition: var(--transition-fast);
  }

  .social-link:hover {
    color: var(--white);
    transform: translateY(-4px);
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4rem;
    padding-bottom: 5rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--zinc-900);
  }

  .column-title {
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    color: var(--zinc-500);
    margin-bottom: 2rem;
  }

  .nav-column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .nav-column a {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--zinc-400);
    transition: var(--transition-fast);
  }

  .nav-column a:hover {
    color: var(--primary);
    padding-left: 0.5rem;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--zinc-600);
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: #10b981;
    border-radius: 0;
    animation: blink 2s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  @media (max-width: 768px) {
    .footer-top { flex-direction: column; gap: 3rem; align-items: flex-start; }
    .footer-nav { grid-template-columns: 1fr; gap: 3rem; }
    .footer-bottom { flex-direction: column; gap: 2rem; align-items: flex-start; }
  }
</style>
