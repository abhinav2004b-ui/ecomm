---
interface HeroItem {
  id: number;
  category: string;
  author: string;
  title: string;
  time: string;
  image: string;
}

const items: HeroItem[] = [
  {
    id: 1,
    category: 'TRADE POLICY',
    author: 'Alex R.',
    title: 'The $800 Loophole Is Dead. Your Margins Are Next.',
    time: '2h ago',
    image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&q=80&w=1200'
  },
  {
    id: 2,
    category: 'MARKET INTEL',
    author: 'Alex R.',
    title: 'Global Shipping Surcharges for Q3 2026: A Forecast',
    time: '4h ago',
    image: 'https://images.unsplash.com/photo-1494412519320-aa613dfb7738?auto=format&fit=crop&q=80&w=800'
  },
  {
    id: 3,
    category: 'STRATEGY',
    author: 'Alex R.',
    title: 'Localization vs Globalization: The Pivot to Nearshoring',
    time: '6h ago',
    image: 'https://images.unsplash.com/photo-1551288049-bbbda536639a?auto=format&fit=crop&q=80&w=800'
  }
];
---

<div class="hero-grid container">
  <div class="main-featured">
    <div class="image-wrapper">
      <img src={items[0].image} alt={items[0].title} class="grayscale" />
      <div class="overlay"></div>
    </div>
    <div class="content">
      <span class="category-tag">{items[0].category}</span>
      <h2 class="hero-title">{items[0].title}</h2>
      <div class="meta">
        <span>By {items[0].author}</span>
        <span class="dot">•</span>
        <span class="amber">{items[0].time}</span>
      </div>
    </div>
  </div>

  <div class="side-grid">
    {items.slice(1).map((item) => (
      <div class="side-item">
        <div class="side-image-wrapper">
          <img src={item.image} alt={item.title} class="side-image grayscale" />
          <div class="side-overlay"></div>
        </div>
        <div class="side-content">
          <span class="side-category">{item.category}</span>
          <h3 class="side-title">{item.title}</h3>
          <span class="side-time">{item.time}</span>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    border: 2px solid var(--black);
    margin-top: 2rem;
    overflow: hidden;
  }

  .main-featured {
    position: relative;
    border-right: 2px solid var(--black);
    cursor: pointer;
    overflow: hidden;
  }

  .image-wrapper {
    position: relative;
    aspect-ratio: 16 / 10;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .main-featured:hover img {
    transform: scale(1.05);
    filter: grayscale(0%);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
  }

  .content {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 3rem;
    color: var(--white);
    pointer-events: none;
  }

  .category-tag {
    display: inline-block;
    background: var(--primary);
    color: var(--black);
    font-size: 0.7rem;
    font-weight: 900;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 0.9;
    margin-bottom: 1.5rem;
    transition: color 0.3s ease;
  }

  .main-featured:hover .hero-title {
    color: var(--primary);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .dot { color: var(--zinc-500); }
  .amber { color: var(--primary); }

  .side-grid {
    display: flex;
    flex-direction: column;
  }

  .side-item {
    flex: 1;
    position: relative;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    cursor: pointer;
  }

  .side-item:first-child {
    border-bottom: 2px solid var(--black);
  }

  .side-image-wrapper {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .side-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.15;
    transition: var(--transition-smooth);
  }

  .side-item:hover .side-image {
    opacity: 0.4;
    transform: scale(1.1);
    filter: grayscale(0%);
  }

  .side-category {
    color: var(--primary);
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .side-title {
    font-size: 1.75rem;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .side-item:hover .side-title {
    text-decoration: underline;
    text-decoration-color: var(--primary);
  }

  .side-time {
    font-size: 0.65rem;
    font-weight: 900;
    color: var(--zinc-500);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .main-featured {
      border-right: none;
      border-bottom: 2px solid var(--black);
    }
  }

  @media (max-width: 768px) {
    .content {
      padding: 1.5rem;
    }
    .hero-title {
      font-size: 2.5rem;
    }
  }
</style>
